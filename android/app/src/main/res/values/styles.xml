<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — black status bar, edge-to-edge -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorPrimary">#E50914</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#E50914</item>
    </style>

    <!-- Used by MainActivity — no action bar, immersive -->
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Launch theme — shown instantly before SplashActivity loads -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <item name="android:windowBackground">#000000</item>
    </style>

    <!-- Splash screen theme — pure black, no icon, no system splash overlay -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Suppress Android 12+ system splash icon so only our SplashActivity shows -->
        <item name="android:windowIsTranslucent">false</item>
    </style>

</resources>
