<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31): override the system splash screen.
         windowSplashScreenBackground = pure black so nothing shows.
         We deliberately do NOT set windowSplashScreenAnimatedIcon so no
         round launcher icon appears — our SplashActivity takes over immediately. -->
    <style name="SplashTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>
</resources>
